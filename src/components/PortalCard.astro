---
import { withUtm } from '../lib/links'

interface Props {
  title: string
  description: string
  href: string
  tag: string
  variant?: 'default' | 'alerta'
  cta?: string
  instagram?: string
  x?: string
  youtube?: string
  website?: string
  socials?: string[]
}

const {
  title,
  description,
  href,
  tag,
  variant = 'default',
  cta,
  instagram,
  x,
  youtube,
  website,
  socials: extraSocials,
} = Astro.props
const outboundHref = withUtm(href)
const domain = new URL(href).hostname.replace(/^www\./, '')
const isAlerta = variant === 'alerta'
const ctaLabel = cta ?? (isAlerta ? 'Por qué evitarla' : 'Visitar')

type SocialType = 'instagram' | 'x' | 'youtube' | 'website'
const SOCIAL_LABEL: Record<SocialType, string> = {
  instagram: 'Instagram',
  x: 'X',
  youtube: 'YouTube',
  website: 'Sitio web',
}

function classifySocial(url: string): SocialType {
  try {
    const host = new URL(url).hostname.replace(/^www\./, '')
    if (host === 'x.com' || host === 'twitter.com') return 'x'
    if (host === 'instagram.com') return 'instagram'
    if (host === 'youtube.com' || host === 'youtu.be') return 'youtube'
  } catch {}
  return 'website'
}

function socialHandle(url: string, type: SocialType): string {
  try {
    if (type === 'website') return new URL(url).hostname.replace(/^www\./, '')
    const path = new URL(url).pathname.replace(/^\/+|\/+$/g, '')
    return path.startsWith('@') ? path : `@${path}`
  } catch {
    return url
  }
}

const isMediaCard = Boolean(x || youtube || website || (extraSocials && extraSocials.length))
const socials = [instagram, x, youtube, website, ...(extraSocials ?? [])]
  .filter((url): url is string => Boolean(url))
  .map((url) => {
    const type = classifySocial(url)
    return { url, type, handle: socialHandle(url, type), label: SOCIAL_LABEL[type] }
  })
const primarySocial = socials[0]
---

<div
  role="listitem"
  class={`group relative flex flex-col rounded-xl border p-6 transition focus-within:shadow-lg ${
    isAlerta
      ? 'border-red-300 bg-red-50 hover:border-red-500 hover:shadow-lg'
      : 'border-slate-200 bg-white hover:border-navy hover:shadow-lg'
  }`}
>
  <span
    class={`mb-3 inline-flex w-fit items-center rounded-full px-3 py-1 text-xs font-bold tracking-wide uppercase ${
      isAlerta ? 'bg-red-600/15 text-red-700' : 'bg-amarillo/30 text-navy'
    }`}
  >
    {tag}
  </span>
  <h3 class={`text-lg font-black ${isAlerta ? 'text-red-700' : 'text-navy'}`}>
    <a
      href={outboundHref}
      target="_blank"
      rel="noopener noreferrer"
      class="after:absolute after:inset-0 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
    >
      {title}
    </a>
  </h3>
  <p class={`mt-2 flex-1 text-sm leading-6 ${isAlerta ? 'text-red-900/80' : 'text-slate-600'}`}>
    {description}
  </p>
  <span
    class={`mt-4 inline-flex items-center gap-1 text-sm font-bold ${
      isAlerta ? 'text-red-700' : 'text-navy'
    }`}
  >
    {ctaLabel}
    <svg
      class="size-4 transition group-hover:translate-x-0.5"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M5 12h14M13 6l6 6-6 6"></path>
    </svg>
  </span>
  {
    isMediaCard ? (
      <div class="relative z-10 mt-4 flex flex-wrap gap-2">
        {socials.map((s) => (
          <a
            href={s.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={`${s.label}: ${s.handle}`}
            title={`${s.label} · ${s.handle}`}
            class="inline-flex size-8 items-center justify-center rounded-lg border border-slate-200 text-navy transition hover:border-navy hover:bg-navy hover:text-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2"
          >
            {s.type === 'x' ? (
              <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
              </svg>
            ) : s.type === 'youtube' ? (
              <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M23.5 6.2a3 3 0 0 0-2.11-2.13C19.53 3.55 12 3.55 12 3.55s-7.53 0-9.39.52A3 3 0 0 0 .5 6.2 31.4 31.4 0 0 0 0 12a31.4 31.4 0 0 0 .5 5.8 3 3 0 0 0 2.11 2.13c1.86.52 9.39.52 9.39.52s7.53 0 9.39-.52A3 3 0 0 0 23.5 17.8 31.4 31.4 0 0 0 24 12a31.4 31.4 0 0 0-.5-5.8zM9.6 15.6V8.4l6.25 3.6z" />
              </svg>
            ) : s.type === 'website' ? (
              <svg
                class="size-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <circle cx="12" cy="12" r="10" />
                <path d="M2 12h20" />
                <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z" />
              </svg>
            ) : (
              <svg
                class="size-4"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect x="2" y="2" width="20" height="20" rx="5" />
                <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
              </svg>
            )}
          </a>
        ))}
      </div>
    ) : primarySocial ? (
      <a
        href={primarySocial.url}
        target="_blank"
        rel="noopener noreferrer"
        class={`relative z-10 mt-3 inline-flex w-fit items-center gap-1.5 text-xs font-semibold transition hover:underline ${
          isAlerta ? 'text-red-600 hover:text-red-700' : 'text-navy hover:text-navy-700'
        }`}
      >
        {primarySocial.type === 'x' ? (
          <svg class="size-3.5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z" />
          </svg>
        ) : (
          <svg
            class="size-3.5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="2" y="2" width="20" height="20" rx="5" />
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
          </svg>
        )}
        {primarySocial.handle}
      </a>
    ) : null
  }
  <span
    class={`mt-2 inline-flex items-center gap-1.5 text-xs font-medium ${
      isAlerta ? 'text-red-500' : 'text-slate-500'
    }`}
  >
    <svg
      class="size-3.5"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <rect x="3" y="11" width="18" height="11" rx="2"></rect>
      <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
    </svg>
    {domain}
  </span>
</div>

