---
interface Props {
  title: string
  description: string
  href: string
  tag: string
}

const { title, description, href, tag } = Astro.props
const domain = new URL(href).hostname.replace(/^www\./, '')
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class="group flex flex-col rounded-xl border border-slate-200 bg-white p-6 transition hover:border-navy hover:shadow-lg focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-navy"
>
  <span
    class="mb-3 inline-flex w-fit items-center rounded-full bg-amarillo/30 px-3 py-1 text-xs font-bold tracking-wide text-navy uppercase"
  >
    {tag}
  </span>
  <h3 class="text-lg font-black text-navy">{title}</h3>
  <p class="mt-2 flex-1 text-sm leading-6 text-slate-600">{description}</p>
  <span class="mt-4 inline-flex items-center gap-1 text-sm font-bold text-navy">
    Visitar
    <svg
      class="size-4 transition group-hover:translate-x-0.5"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M5 12h14M13 6l6 6-6 6"></path>
    </svg>
  </span>
  <span class="mt-2 inline-flex items-center gap-1.5 text-xs font-medium text-slate-400">
    <svg
      class="size-3.5"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <rect x="3" y="11" width="18" height="11" rx="2"></rect>
      <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
    </svg>
    {domain}
  </span>
</a>

