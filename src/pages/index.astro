---
import PortalCard from '../components/PortalCard.astro'
import Directory from '../components/Directory.tsx'
import {
  acciones,
  portales,
  otrasDonaciones,
  advertencias,
  informacionAdicional,
  buildDirectory,
} from '../data/directory'
import { withUtm } from '../lib/links'
import '../styles/global.css'

const directory = buildDirectory()

const site = 'https://dondeayudarvenezuela.com'
const title = '¿Dónde ayudar a Venezuela? — Terremoto 2026: dónde donar, reportar y denunciar'
const description =
  'Directorio que reúne las plataformas activas tras el terremoto de Venezuela (junio 2026): dónde donar, reportar daños, denunciar irregularidades, buscar personas y encontrar ayuda profesional.'
const ogImage = `${site}/og-image.png`

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: '¿Dónde ayudar a Venezuela?',
  url: site,
  description,
  inLanguage: 'es',
  publisher: {
    '@type': 'Organization',
    name: '¿Dónde ayudar a Venezuela?',
    url: site,
    logo: `${site}/android-chrome-512x512.png`,
  },
  about: {
    '@type': 'Event',
    name: 'Terremoto de Venezuela 2026',
    startDate: '2026-06-24',
    location: {
      '@type': 'Place',
      name: 'Venezuela',
    },
  },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: [
      ...acciones,
      ...portales,
      ...otrasDonaciones,
      ...informacionAdicional,
    ].map((item, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: item.title,
      url: item.href,
    })),
  },
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    />
    <link rel="canonical" href={site} />
    <meta name="msvalidate.01" content="4F34679354B83A11237DBF4611EF345F" />
    <meta name="theme-color" content="#071a3d" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="¿Dónde ayudar a Venezuela?" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="¿Dónde ayudar a Venezuela? Directorio de ayuda tras el terremoto de 2026"
    />
    <meta property="og:url" content={site} />
    <meta property="og:locale" content="es_VE" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta
      name="twitter:image:alt"
      content="¿Dónde ayudar a Venezuela? Directorio de ayuda tras el terremoto de 2026"
    />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <body class="flex min-h-screen flex-col bg-lienzo text-slate-800">
    <header class="sticky top-0 z-40 border-b border-slate-200 bg-white/95 backdrop-blur">
      <div class="mx-auto flex max-w-5xl items-center gap-3 px-4 py-4 sm:px-6">
        <span class="grid size-10 shrink-0 place-items-center rounded-md bg-amarillo text-navy">
          <svg
            class="size-6"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path
              d="M11 14h2a3 3 0 0 0 0-6h-3l-3 3M7 16l3 3 7-7M5 11l3-3"
            ></path>
          </svg>
        </span>
        <span class="hidden text-lg font-black text-navy sm:inline">¿Dónde ayudar a Venezuela?</span>
        <Directory client:idle items={directory} />
      </div>
    </header>

    <main class="flex-1">
      <section class="mx-auto w-full max-w-5xl px-4 pt-12 pb-8 sm:px-6 sm:pt-16">
        <p class="text-sm font-bold tracking-wide text-slate-500 uppercase">
          Meta-sitio · Terremoto 24 de junio de 2026
        </p>
        <h1 class="mt-3 text-3xl leading-tight font-black text-navy sm:text-5xl">
          Unimos esfuerzos para ayudar a Venezuela
        </h1>
        <p class="mt-5 text-base leading-7 text-slate-600 sm:text-lg">
          Un directorio de iniciativas verificadas que ya reciben ayuda tras el terremoto. Tú eliges
          dónde colaborar y tu aporte llega directo a cada organización.
        </p>

        <div class="mt-8 grid gap-4 sm:grid-cols-3">
          {
            acciones.map((accion) => (
              <div class="group relative flex flex-col rounded-xl bg-navy p-6 text-white transition hover:bg-navy-700">
                <span class="text-xl font-black">
                  <a
                    href={withUtm(accion.href)}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="after:absolute after:inset-0 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-amarillo"
                  >
                    {accion.title}
                  </a>
                </span>
                <span class="mt-2 flex-1 text-sm leading-6 text-slate-200">{accion.description}</span>
                {accion.instagram && (
                  <a
                    href={accion.instagram}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="relative z-10 mt-3 inline-flex w-fit items-center gap-1.5 text-xs font-semibold text-amarillo hover:underline"
                  >
                    <svg
                      class="size-3.5"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <rect x="2" y="2" width="20" height="20" rx="5" />
                      <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z" />
                      <line x1="17.5" y1="6.5" x2="17.51" y2="6.5" />
                    </svg>
                    {`@${new URL(accion.instagram).pathname.replace(/^\/+|\/+$/g, '')}`}
                  </a>
                )}
                <span class="mt-4 inline-flex items-center gap-1.5 text-xs font-medium text-slate-300">
                  <svg
                    class="size-3.5"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <rect x="3" y="11" width="18" height="11" rx="2" />
                    <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                  </svg>
                  {new URL(accion.href).hostname.replace(/^www\./, '')}
                </span>
              </div>
            ))
          }
        </div>
      </section>

      <section class="mx-auto w-full max-w-5xl px-4 py-8 sm:px-6">
        <h2 class="text-2xl font-black text-navy">Otras formas de ayudar y encontrar ayuda</h2>
        <div
          class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3"
          data-collapsible
          data-collapsed="true"
        >
          {portales.map((portal) => <PortalCard {...portal} />)}
        </div>
        {
          portales.length > 3 && (
            <button
              type="button"
              class="ver-mas mt-6 inline-flex items-center gap-1.5 rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-bold text-navy transition hover:border-navy focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-navy"
              aria-expanded="false"
              data-ver-mas={`Ver más (${portales.length - 3})`}
              data-ocultar="Ocultar"
            >
              Ver más ({portales.length - 3})
            </button>
          )
        }
      </section>

      <section class="mx-auto w-full max-w-5xl px-4 py-8 sm:px-6">
        <h2 class="text-2xl font-black text-navy">Otras formas de donar</h2>
        <p class="mt-2 text-sm leading-6 text-slate-600">
          Organizaciones y campañas que también reciben donaciones para la emergencia.
        </p>
        <div
          class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3"
          data-collapsible
          data-collapsed="true"
        >
          {otrasDonaciones.map((portal) => <PortalCard {...portal} />)}
        </div>
        {
          otrasDonaciones.length > 3 && (
            <button
              type="button"
              class="ver-mas mt-6 inline-flex items-center gap-1.5 rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-bold text-navy transition hover:border-navy focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-navy"
              aria-expanded="false"
              data-ver-mas={`Ver más (${otrasDonaciones.length - 3})`}
              data-ocultar="Ocultar"
            >
              Ver más ({otrasDonaciones.length - 3})
            </button>
          )
        }
        <p class="mt-6 text-xs leading-5 text-slate-500">
          No recibimos ni gestionamos donaciones. El botón de donar te lleva al canal oficial de
          cada organización y te mostramos el dominio real antes de que salgas. Para ver qué trampas
          evitar antes de transferir, lee{' '}
          <a
            href={withUtm('https://donarseguro.com/dinero/seguridad')}
            target="_blank"
            rel="noopener noreferrer"
            class="font-semibold text-navy underline hover:text-navy-700"
            >cómo donar sin caer en fraude</a
          >.
        </p>
      </section>

      <section class="mx-auto w-full max-w-5xl px-4 py-8 sm:px-6">
        <h2 class="text-2xl font-black text-red-700">Dónde NO donar</h2>
        <p class="mt-2 text-sm leading-6 text-slate-600">
          Organizaciones que perdieron su independencia. Te recomendamos evitarlas como canal de
          donación.
        </p>
        <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {advertencias.map((item) => <PortalCard {...item} variant="alerta" />)}
        </div>
      </section>

      <section class="mx-auto w-full max-w-5xl px-4 py-8 sm:px-6">
        <h2 class="text-2xl font-black text-navy">Información adicional</h2>
        <p class="mt-2 text-sm leading-6 text-slate-600">
          Fuentes para verificar organizaciones, contrastar las cifras del terremoto y seguir la
          actividad sísmica: organismos oficiales, periodismo independiente, derechos humanos e
          internet libre.
        </p>
        <div
          class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-3"
          data-collapsible
          data-collapsed="true"
        >
          {informacionAdicional.map((recurso) => <PortalCard {...recurso} />)}
        </div>
        {
          informacionAdicional.length > 3 && (
            <button
              type="button"
              class="ver-mas mt-6 inline-flex items-center gap-1.5 rounded-full border border-slate-200 bg-white px-4 py-2 text-sm font-bold text-navy transition hover:border-navy focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-navy"
              aria-expanded="false"
              data-ver-mas={`Ver más (${informacionAdicional.length - 3})`}
              data-ocultar="Ocultar"
            >
              Ver más ({informacionAdicional.length - 3})
            </button>
          )
        }
      </section>
    </main>

    <footer class="mt-4 border-t border-slate-200 bg-white">
      <div class="mx-auto w-full max-w-5xl px-4 py-8 sm:px-6">
        <p class="text-xs leading-5 text-slate-500">
          Hecho con&nbsp;
          <svg
            class="inline size-3.5 align-[-2px] text-red-500"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path
              d="M12 21s-6.716-4.35-9.428-8.06C.86 10.223 1.05 6.94 3.343 5.05c2.02-1.66 4.79-1.2 6.303.42L12 7.8l2.354-2.33c1.513-1.62 4.283-2.08 6.303-.42 2.293 1.89 2.483 5.173.771 7.89C18.716 16.65 12 21 12 21z"
            ></path>
          </svg>
          <span class="sr-only">corazón</span>. Puedes auditar el código fuente, es un proyecto open
          source en{' '}
          <a
            href="https://github.com/luismalamoc/dondeayudarvenezuelalandingpage"
            target="_blank"
            rel="noopener noreferrer"
            class="font-semibold text-slate-600 hover:text-navy">GitHub</a
          >, o escribe a{' '}
          <a
            href="mailto:luismalamoc@gmail.com"
            class="font-semibold text-slate-600 hover:text-navy">luismalamoc@gmail.com</a
          >.
        </p>
      </div>
    </footer>

    <script>
      // Baraja las tarjetas de cada sección con "Ver más" en cada visita (Fisher-Yates),
      // para que rote qué organizaciones se muestran primero. El HTML mantiene el orden
      // original para buscadores; solo cambia el orden visual en el cliente.
      document.querySelectorAll<HTMLElement>('[data-collapsible]').forEach((grid) => {
        const cards = Array.from(grid.children)
        for (let i = cards.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1))
          ;[cards[i], cards[j]] = [cards[j], cards[i]]
        }
        cards.forEach((card) => grid.appendChild(card))
      })

      document.querySelectorAll<HTMLElement>('.ver-mas').forEach((btn) => {
        btn.addEventListener('click', () => {
          const section = btn.closest('section')
          const grid = section?.querySelector('[data-collapsible]')
          if (!grid) return
          const wasCollapsed = grid.getAttribute('data-collapsed') === 'true'
          grid.setAttribute('data-collapsed', String(!wasCollapsed))
          btn.setAttribute('aria-expanded', String(wasCollapsed))
          const label = wasCollapsed ? btn.dataset.ocultar : btn.dataset.verMas
          if (label) btn.textContent = label
        })
      })
    </script>
  </body>
</html>
